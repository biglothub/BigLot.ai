OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Shared fallback model used by the indicator engine, Telegram, and chat when
# NORMAL_AI_MODEL / AGENT_AI_MODEL are not set.
# gpt-4o | gpt-4o-mini | o3-mini | deepseek | deepseek-r1 | claude-sonnet | claude-haiku | gemini-2.5-flash | gemini-2.5-pro
AI_MODEL=gpt-4o

# Chat-specific overrides (optional)
NORMAL_AI_MODEL=deepseek
AGENT_AI_MODEL=gpt-4o

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# Optional server-side override if you don't want to reuse PUBLIC_SUPABASE_URL
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tools / debugging
TAVILY_API_KEY=
DEEP_RESEARCH_MAX_ITERATIONS=8

# Telegram Phase 1
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Optional but recommended: verify Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=
# Force webhook secret validation in all envs (production is already required by default)
TELEGRAM_REQUIRE_WEBHOOK_SECRET=0
# Per-account inbound Telegram user message limit (per minute)
TELEGRAM_RATE_LIMIT_PER_MINUTE=15

# Discussion Mode: override which model each panelist uses (optional)
# DISCUSSION_BULL_MODEL=gpt-4o
# DISCUSSION_BEAR_MODEL=deepseek
# DISCUSSION_MODERATOR_MODEL=deepseek-r1

# Debug: return the selected mode immediately from /api/chat (no OpenAI call)
# BIGLOT_CHAT_ECHO_MODE=1
