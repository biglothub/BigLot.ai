# ─────────────────────────────────────────────
#  Supabase
# ─────────────────────────────────────────────
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
#  AI Provider API Keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ─────────────────────────────────────────────
#  AI Model Configuration
#  Available: gpt-4o, gpt-4o-mini, o3-mini,
#             deepseek, deepseek-r1,
#             claude-sonnet, claude-haiku,
#             gemini-2.5-flash, gemini-2.5-pro,
#             minimax-text-01, minimax-m1,
#             minimax-m2.5, minimax-m2.5-highspeed
# ─────────────────────────────────────────────
AI_MODEL=minimax-m2.5           # Fallback if mode-specific var is not set
NORMAL_AI_MODEL=minimax-m2.5   # normal / research / discussion mode
AGENT_AI_MODEL=gpt-4o          # agent mode only

# ─────────────────────────────────────────────
#  Discussion Mode — Per-Panelist Model
# ─────────────────────────────────────────────
DISCUSSION_BULL_MODEL=minimax-m2.5
DISCUSSION_BEAR_MODEL=minimax-m2.5
DISCUSSION_MODERATOR_MODEL=minimax-m2.5

# ─────────────────────────────────────────────
#  Web Search  (Tavily — https://tavily.com)
# ─────────────────────────────────────────────
TAVILY_API_KEY=
DEEP_RESEARCH_MAX_ITERATIONS=8

# ─────────────────────────────────────────────
#  Telegram Bot
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_REQUIRE_WEBHOOK_SECRET=0
TELEGRAM_RATE_LIMIT_PER_MINUTE=15

# ─────────────────────────────────────────────
#  Debug
# ─────────────────────────────────────────────
# BIGLOT_CHAT_ECHO_MODE=1
